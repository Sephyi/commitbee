 /// Simplified config processing using iterators.
 fn process_config(config: &Config) -> Vec<String> {
     config
         .get_entries()
         .iter()
         .filter(|e| e.is_valid())
         .map(|e| format!("{}={}", e.name(), e.value()))
         .collect()
 }
