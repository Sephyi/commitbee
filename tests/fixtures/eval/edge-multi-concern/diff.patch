+use myproject::services::metrics::MetricsCollector;
+
+#[test]
+fn test_elapsed_is_non_negative() {
+    let collector = MetricsCollector::new();
+    std::thread::sleep(std::time::Duration::from_millis(10));
+    assert!(collector.elapsed_ms() >= 10);
+}
