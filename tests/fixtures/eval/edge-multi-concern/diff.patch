+use std::time::Instant;
+
+/// Simple timing metrics collector.
+pub struct MetricsCollector {
+    start: Instant,
+    labels: Vec<String>,
+}
+
+impl MetricsCollector {
+    pub fn new() -> Self {
+        Self {
+            start: Instant::now(),
+            labels: Vec::new(),
+        }
+    }
+
+    pub fn elapsed_ms(&self) -> u128 {
+        self.start.elapsed().as_millis()
+    }
+}
