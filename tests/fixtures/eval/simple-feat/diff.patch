+use crate::error::Result;
+
+/// Validates commit messages against project conventions.
+pub struct CommitValidator {
+    max_subject_len: usize,
+}
+
+impl CommitValidator {
+    pub fn new(max_subject_len: usize) -> Self {
+        Self { max_subject_len }
+    }
+
+    /// Check if a commit message subject line is within the length limit.
+    pub fn validate_subject(&self, subject: &str) -> Result<()> {
+        if subject.len() > self.max_subject_len {
+            return Err(crate::error::Error::InvalidCommitMessage(
+                format!("Subject too long: {} chars (max {})", subject.len(), self.max_subject_len),
+            ));
+        }
+        Ok(())
+    }
+}
+
