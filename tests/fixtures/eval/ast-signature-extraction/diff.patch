+use crate::error::Result;
+
+pub struct InputValidator {
+    max_length: usize,
+}
+
+impl InputValidator {
+    pub fn new(max_length: usize) -> Self {
+        Self { max_length }
+    }
+
+    pub fn validate(&self, input: &str) -> Result<()> {
+        if input.len() > self.max_length {
+            return Err(crate::error::Error::Config("input too long".into()));
+        }
+        Ok(())
+    }
+}
